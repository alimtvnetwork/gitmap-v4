---
title: GitMap Core Schema (Simplified) — v15 Phase 1.1
---
erDiagram
    Repo {
        INTEGER RepoId PK
        TEXT Slug
        TEXT RepoName
        TEXT HttpsUrl
        TEXT SshUrl
        TEXT Branch
        TEXT RelativePath
        TEXT AbsolutePath UK
        TEXT CloneInstruction
        TEXT Notes
        TEXT CurrentVersionTag
        INTEGER CurrentVersionNum
        TEXT CreatedAt
        TEXT UpdatedAt
    }

    Groups {
        INTEGER Id PK
        TEXT Name UK
        TEXT Description
        TEXT Color
        TEXT CreatedAt
    }

    GroupRepo {
        INTEGER GroupId FK
        INTEGER RepoId FK
    }

    Aliases {
        INTEGER Id PK
        TEXT Alias UK
        INTEGER RepoId FK
        TEXT CreatedAt
    }

    RepoVersionHistory {
        INTEGER Id PK
        INTEGER RepoId FK
        TEXT FromVersionTag
        INTEGER FromVersionNum
        TEXT ToVersionTag
        INTEGER ToVersionNum
        TEXT FlattenedPath
        TEXT CreatedAt
    }

    Releases {
        INTEGER Id PK
        TEXT Version
        TEXT Tag UK
        TEXT Branch
        TEXT SourceBranch
        TEXT CommitSha
        TEXT Changelog
        TEXT Notes
        INTEGER Draft
        INTEGER PreRelease
        INTEGER IsLatest
        TEXT Source
        TEXT CreatedAt
    }

    Repo ||--o{ GroupRepo : "belongs to"
    Groups ||--o{ GroupRepo : "contains"
    Repo ||--o{ Aliases : "has"
    Repo ||--o{ RepoVersionHistory : "tracks"
    Repo ||--o{ Releases : "published"
